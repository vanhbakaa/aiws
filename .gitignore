# Dependencies
node_modules/

# Build output (regenerated by `npm run build` / `npm run build:bin`)
dist/
dist-bin/

# Electron GUI build output (electron-vite → out/, electron-builder installers → dist-gui/)
out/
dist-gui/

# Bun single-file compile temp artifacts (can be ~95 MB each)
*.bun-build

# Logs
*.log
npm-debug.log*

# Local env / secrets
.env
.env.*

# aiws conversation handoff file (regenerated per provider switch)
.aiws-handoff.md

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
