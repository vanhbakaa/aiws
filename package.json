{
  "name": "aiws",
  "version": "0.2.2",
  "description": "Desktop workspace for AI coding CLIs. Run Claude Code, Codex and others side by side, isolated per project.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "out/main/index.js",
  "author": "vanhbakaa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanhbakaa/aiws.git"
  },
  "homepage": "https://github.com/vanhbakaa/aiws#readme",
  "bugs": {
    "url": "https://github.com/vanhbakaa/aiws/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gui:dev": "electron-vite dev",
    "gui:typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "gui:build": "electron-vite build",
    "gui:preview": "electron-vite preview",
    "gui:package": "electron-vite build && electron-builder --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/headless": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.5"
  }
}
